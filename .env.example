# ===============================================
# FORTHEWEEBS - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ===============================================

# ----------------
# SUPABASE
# ----------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ----------------
# STRIPE PAYMENTS
# ----------------
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Price IDs (see HOW_TO_GET_STRIPE_PRICE_IDS.md)
STRIPE_PRICE_SOVEREIGN=price_1ABC123...
STRIPE_PRICE_FULL_MONTHLY=price_1DEF456...
STRIPE_PRICE_FULL_LIFETIME=price_1GHI789...
STRIPE_PRICE_HALF=price_1JKL012...
STRIPE_PRICE_ADVANCED=price_1MNO345...
STRIPE_PRICE_BASIC=price_1PQR678...
STRIPE_PRICE_STARTER=price_1STU901...

# ----------------
# ANTHROPIC (Mico AI - FREE for everyone!)
# ----------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ----------------
# OPENAI (For AI Bug Fixer)
# ----------------
OPENAI_API_KEY=sk-your-openai-key-here

# ----------------
# GITHUB (For AI Bug Fixer PR creation)
# ----------------
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=fortheweebs

# ----------------
# URLS
# ----------------
VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001/api

# ----------------
# NODE ENVIRONMENT
# ----------------
NODE_ENV=development

# ----------------
# OPTIONAL
# ----------------
PORT=3001
