# ===============================================
# FORTHEWEEBS - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ===============================================

# ============================================================================
# 🚨 CRITICAL - CSAM DETECTION (REQUIRED BY FEDERAL LAW) 🚨
# Setup Priority: #1 - DO THIS FIRST
# ============================================================================

# Microsoft PhotoDNA API (REQUIRED for CSAM detection)
# Sign up at: https://www.microsoft.com/en-us/photodna
# Approval takes 2-4 weeks - START NOW
PHOTODNA_API_KEY=your_photodna_api_key_here

# OR Google CSAI Match API (Alternative to PhotoDNA)
# Sign up at: https://www.google.com/safebrowsing/csai/
# Faster approval than PhotoDNA
GOOGLE_CSAI_API_KEY=your_google_csai_api_key_here

# NCMEC CyberTipline Reporting (REQUIRED - Federal Law)
# Register at: https://www.cybertipline.org/
# You'll receive an ESP ID and API key
NCMEC_ESP_ID=your_ncmec_esp_id_here
NCMEC_API_KEY=your_ncmec_api_key_here

# Legal Contact Info (REQUIRED for NCMEC registration)
LEGAL_CONTACT_NAME=Your Name
LEGAL_CONTACT_EMAIL=legal@fortheweebs.com
LEGAL_CONTACT_PHONE=+1-555-123-4567

# ============================================================================
# IMAGE CONTENT SCANNING (Copyright/Trademark Detection)
# Setup Priority: #2
# ============================================================================

# Google Cloud Vision API (RECOMMENDED)
# Sign up at: https://console.cloud.google.com/
# Free tier: 1,000 images/month
# After: $1.50 per 1,000 images
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# AWS Rekognition (Optional backup)
# Sign up at: https://aws.amazon.com/rekognition/
# Free tier: 5,000 images/month (first year only)
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# ============================================================================
# AI MODERATION (Text & Image Analysis)
# Setup Priority: #2
# ============================================================================

# OpenAI Moderation API (FREE - No cost!)
# Sign up at: https://platform.openai.com/
# Moderation API is completely free
VITE_OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_API_KEY=sk-your_openai_api_key_here

# Anthropic Claude API (Optional additional moderation)
# Sign up at: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google AI (Gemini) - Optional
VITE_GOOGLE_AI_KEY=your_google_ai_key_here

# ============================================================================
# PAYMENT PROCESSING (Stripe)
# Setup Priority: #3
# ============================================================================

# Stripe API Keys
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Price IDs (see HOW_TO_GET_STRIPE_PRICE_IDS.md)
STRIPE_PRICE_SOVEREIGN=price_1ABC123...
STRIPE_PRICE_FULL_MONTHLY=price_1DEF456...
STRIPE_PRICE_FULL_LIFETIME=price_1GHI789...
STRIPE_PRICE_HALF=price_1JKL012...
STRIPE_PRICE_ADVANCED=price_1MNO345...
STRIPE_PRICE_BASIC=price_1PQR678...
STRIPE_PRICE_STARTER=price_1STU901...

# ============================================================================
# DATABASE & BACKEND
# ============================================================================

# Supabase (if using)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================================================
# ADULT CONTENT COMPLIANCE (18 U.S.C. § 2257)
# Setup Priority: #3
# ============================================================================

# ID Document Encryption Key (REQUIRED for adult content)
# Generate a strong random key: openssl rand -base64 32
# KEEP THIS SECRET - used to encrypt government IDs
ID_ENCRYPTION_KEY=your_secure_encryption_key_here_change_this_immediately

# CCBill Payment Processing (for adult content)
# Sign up at: https://www.ccbill.com/
# Required for adult content creators (Stripe doesn't support adult content)
CCBILL_ACCOUNT_ID=your_ccbill_account_id
CCBILL_SUB_ACCOUNT_ID=your_ccbill_sub_account_id
CCBILL_FLEXFORMS_ID=your_flexforms_id
CCBILL_SALT=your_ccbill_salt_key

# Segpay Payment Processing (alternative to CCBill)
# Sign up at: https://www.segpay.com/
SEGPAY_PACKAGE_ID=your_segpay_package_id
SEGPAY_API_KEY=your_segpay_api_key

# 2257 Custodian of Records (REQUIRED - Federal Law)
# Physical address where performer records are kept
CUSTODIAN_NAME=Your Name or Company Name
CUSTODIAN_ADDRESS_LINE1=123 Main Street
CUSTODIAN_ADDRESS_LINE2=Suite 100
CUSTODIAN_CITY=Your City
CUSTODIAN_STATE=CA
CUSTODIAN_ZIP=12345
CUSTODIAN_PHONE=+1-555-123-4567
CUSTODIAN_EMAIL=custodian@fortheweebs.com

# ============================================================================
# GITHUB (For AI Bug Fixer PR creation)
# ============================================================================

GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=fortheweebs

# ============================================================================
# DEPLOYMENT
# ============================================================================

# URLs
VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001/api

# Environment
NODE_ENV=development
PORT=3001

# ============================================================================
