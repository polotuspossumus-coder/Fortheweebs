# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Stripe Configuration
# Get your keys from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe Webhook Secret
# For local dev: Run `stripe listen --forward-to localhost:3001/api/stripe-webhook`
# For production: Get from Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# OpenAI Configuration
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# GitHub Configuration
# Get from: https://github.com/settings/tokens (needs 'repo' scope)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_REPO_OWNER=polotuspossumus-coder
GITHUB_REPO_NAME=Fortheweebs

# Supabase Configuration
# Get from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

JWT_SECRET=your_secure_random_jwt_secret_here
DATABASE_URL=your_database_url_here
DISCORD_BOT_TOKEN=your_discord_token_here

# Admin Authentication (IMPORTANT: Change these values!)
VITE_ADMIN_SECRET_KEY=your_secure_admin_secret_key_here
VITE_ADMIN_RECOVERY_PASSWORD=your_secure_recovery_password_here
VITE_ADMIN_USERNAME=your_admin_username
VITE_ADMIN_PASSWORD=your_secure_admin_password
VITE_OWNER_PHONE_NUMBER=+1234567890
VITE_BACKUP_EMAIL=your_backup_email@example.com

# Security Questions (lowercase answers)
VITE_SECURITY_ANSWER_1=your_answer_1
VITE_SECURITY_ANSWER_2=your_answer_2
VITE_SECURITY_ANSWER_3=your_answer_3

# API Configuration
VITE_API_URL=http://localhost:3001/api
VITE_APP_URL=http://localhost:3002
VITE_API_BASE_URL=https://your-api-domain.com/api
API_PORT=3001
PORT=3000
NODE_ENV=development
