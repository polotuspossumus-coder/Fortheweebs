{
  "name": "fortheweebs",
  "version": "1.8.0",
  "description": "Sovereign creator-first platform built on Vanguard",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "dev:server": "nodemon server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "node scripts/inject-env.js && vite build",
    "build:agents": "tsc --project tsconfig.agents.json",
    "preview": "vite preview",
    "server": "node server.js",
    "setup": "echo 'Skipping face models for now'",
    "postinstall": "echo 'Skipping postinstall'",
    "lint": "eslint . --ext .js,.ts,.jsx,.tsx",
    "test": "vitest",
    "analyze": "node scripts/analyze-bundle.js",
    "android:build": "npm run build && npx cap sync android && npx cap copy android",
    "android:open": "npx cap open android",
    "android:run": "npm run android:build && npx cap run android",
    "android:release": "npm run build && npx cap sync android && cd android && .\\gradlew assembleRelease && cd ..",
    "android:bundle": "npm run build && npx cap sync android && cd android && .\\gradlew bundleRelease && cd .."
  },
  "keywords": [
    "creator",
    "platform",
    "vanguard",
    "fortheweebs"
  ],
  "author": "Jacob Morris",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^8.56.0",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@capacitor/android": "^7.4.4",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@capacitor/ios": "^7.4.4",
    "@octokit/rest": "^21.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.0",
    "@react-three/xr": "^6.6.27",
    "@stripe/stripe-js": "^8.4.0",
    "@supabase/supabase-js": "^2.81.1",
    "@vladmandic/face-api": "^1.7.15",
    "axios": "^1.6.0",
    "chart.js": "^4.5.1",
    "concurrently": "^9.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "multer": "^2.0.2",
    "nodemon": "^3.1.9",
    "openai": "^4.79.1",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "socket.io": "^4.8.1",
    "stripe": "^19.3.1",
    "three": "^0.181.0",
    "ws": "^8.18.3"
  }
}
